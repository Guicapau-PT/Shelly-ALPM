<?xml version="1.0" encoding="UTF-8"?>
<interface>
  <requires lib="gtk" version="4.0"/>
  <object class="GtkWindow" id="PackageWindow">
    <property name="title">Package Details</property>
    <property name="default-width">600</property>
    <property name="default-height">500</property>
    <child>
      <object class="GtkBox">
        <property name="orientation">vertical</property>
        <property name="margin-start">15</property>
        <property name="margin-end">15</property>
        <property name="margin-top">15</property>
        <property name="margin-bottom">15</property>
        <property name="spacing">10</property>
        <child>
          <object class="GtkLabel" id="package_name">
            <property name="label">Package Name</property>
            <style>
              <class name="title-2"/>
            </style>
          </object>
        </child>
        <child>
          <object class="GtkLabel" id="package_description">
            <property name="label">Package Description goes here.</property>
            <property name="wrap">true</property>
          </object>
        </child>
        <child>
          <object class="GtkSeparator"/>
        </child>
        <child>
          <object class="GtkBox" id="info_grid">
             <property name="orientation">vertical</property>
             <property name="spacing">5</property>
             <!-- Placeholder for details -->
          </object>
        </child>
      </object>
    </child>
  </object>
</interface>
